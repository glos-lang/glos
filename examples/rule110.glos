main :: () {
    b: [30]i32

    b[b.count - 2] = 1
    for i := 0; i < b.count - 2; i += 1 {
        for i := 0; i < b.count; i += 1 {
            if bool(b[i]) {
                print('*')
            } else {
                print(' ')
            }
        }
        print('\n')

        pattern := (b[0] << 1) | b[1]
        for j := 1; j < b.count - 1; j += 1 {
            pattern = ((pattern << 1) & 7) | b[j + 1]
            b[j] = (110 >> pattern) & 1
        }
    }
}
