package io

pub fn write(s []u8) {
	when #OS == "Linux" {
		extern {
			var stdout rawptr
		}
	} else {
		extern {
			#link "__stdoutp"
			var stdout rawptr
		}
	}

	extern {
		fn fwrite(data rawptr, count i64, size i64, stream rawptr) i64
	}

	fwrite(<rawptr> s.data, s.count, sizeof<u8>, stdout)
}
