package C

pub extern {
	when #OS == "Linux" {
		var stdout rawptr
		var stderr rawptr
	} else {
		#link "__stdoutp"
		var stdout rawptr
		#link "__stderrp"
		var stderr rawptr
	}
	fn fwrite(data rawptr, count i64, size i64, stream rawptr) i64
	fn snprintf(buffer &u8, capacity i64, fmt &u8, ...) i32
}
