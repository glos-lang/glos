File :: distinct rawptr

extern {
    printf :: (fmt: &char, ...) -> i32
    fprintf :: (f: File, fmt: &char, ...) -> i32
    fwrite :: (ptr: rawptr, size: i64, count: i64, f: File)
    fflush :: (f: File)
    abort :: ()
    exit :: (code: i32)
    memcmp :: (a: rawptr, b: rawptr, n: i64) -> i32
}

#if PLATFORM == {
case .Linux
    extern {
        stdin: File
        stdout: File
        stderr: File
    }

case .MacOS
    extern {
        #link "__stdinp"  stdin: File
        #link "__stdoutp" stdout: File
        #link "__stderrp" stderr: File
    }

case .Windows
    stdin: File
    stdout: File
    stderr: File
}
