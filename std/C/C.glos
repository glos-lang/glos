package C

pub extern {
	when #OS == "Linux" {
		var stdout rawptr
		var stderr rawptr
	} else {
		#link "__stdoutp"
		var stdout rawptr
		#link "__stderrp"
		var stderr rawptr
	}
	fn fwrite(data rawptr, count u64, size u64, stream rawptr) u64
	fn snprintf(buffer &i8, capacity u64, fmt &i8, ...) i32
}
