A, B :: 69, 420
c, d := 1337, 80085
e, f: i64

main :: () {
    assert(A == 69)
    assert(B == 420)
    assert(c == 1337)
    assert(d == 80085)
    assert(e == 0)
    assert(f == 0)

    g, h := 69, 420
    assert(g == 69)
    assert(h == 420)

    g, h = h, g
    assert(g == 420)
    assert(h == 69)
}
