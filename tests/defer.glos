foo :: () -> i64 {
	println("foo()")
	return 69
}

bar :: () -> i64 {
	defer println("defer")
	return foo()
}

main :: () {
	bar()
}

println :: (s: string) {
    extern {
        putchar :: (c: i32) -> i32
    }

    for i := 0; i < s.count; i += 1 {
        putchar(i32(s[i]))
    }

    putchar(i32('\n'))
}
