main :: () {
    acc := 42
    println(acc)

    acc += 10
    println(acc)

    acc -= 5
    println(acc)

    acc *= 2
    println(acc)

    acc /= 3
    println(acc)

    acc <<= 1
    println(acc)

    acc >>= 2
    println(acc)

    acc |= 8
    println(acc)

    acc &= 15
    println(acc)

    acc %= 4
    println(acc)
}
