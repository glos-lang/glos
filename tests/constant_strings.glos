fn println(s [u8]) {
    extern fn putchar(ch i32) i32

    for var i = 0; i < s.count; i += 1 {
        putchar(<i32> s[i])
    }

    putchar(<i32> '\n')
}

const A = "Hello, world!"
const B = "Foo " + "Bar"
const C = ("Foo " + "Bar").count
const D = "Foo Bar Baz"[4..7]
const E = "HEHE"[1]

fn main() {
    println(A)
    println(B)
    print C
    println(D)
    print E
}
