mod main

fn println(s []u8) {
    extern {
        fn putchar(ch i32) i32
    }

    for var i = 0; i < len(s); i += 1 {
        putchar(<i32> s[i])
    }

    putchar(<i32> '
')
}

const A = "Hello, world!"
const B = "Foo " + "Bar"
const C = len("Foo " + "Bar")
const D = "Foo Bar Baz"[4..7]
const E = "HEHE"[1]

fn main() {
    println(A)
    println(B)
    print C
    println(D)
    print E
}
