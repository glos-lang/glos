fn println_str(s str) {
    extern fn putchar(ch i32) i32

    for var i = 0; i < s.count; i += 1 {
        putchar(<i32> s[i])
    }

    putchar(<i32> '\n')
}

fn println_cstr(s cstr) {
    extern fn puts(s cstr) i32
    puts(s)
}

const STRING = "Hello, world!"
const CSTRING = c"Foo, Bar!"

fn main() {
    println_str(STRING)
    println_cstr(CSTRING)
}
