main :: () {
    // Arithmetics
    println(34 + 35)
    println(500 - 80)
    println(23 * 3)
    println(1260 / 3)
    println(17 * 2 - -35)
    println(10 % 4 * (100 + 110))

    // Bitwise
    println(276 >> 2)
    println(105 << 2)
    println(~-70)
    println(160 | 260)
    println(77 & 103)
    println(~-419 + 10 & 3)

    // Comparisons
    println(2 > 1)
    println(1 > 1)
    println(0 > 1)

    println(2 >= 1)
    println(1 >= 1)
    println(0 >= 1)

    println(1 < 2)
    println(1 < 1)
    println(1 < 0)

    println(1 <= 2)
    println(1 <= 1)
    println(1 <= 0)

    println(1 == 1)
    println(1 == 2)

    println(1 != 2)
    println(1 != 1)
}
