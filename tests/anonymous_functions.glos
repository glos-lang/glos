package main

import "fmt"

fn foo() {
    fmt::println(1337)
}

fn map(x i64, f fn (i64) i64) i64 {
    return f(x)
}

fn main() {
    fmt::println((fn (x i64, y i64) i64 {
        return x + y
    })(34, 35))

    fmt::println(map(210, fn (x i64) i64 {
        return x * 2
    }))

    (fn () {
        foo()
    })()
}
