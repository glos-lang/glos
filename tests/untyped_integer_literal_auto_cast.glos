package main

import "fmt"

fn a(x i8)  { fmt.println(x) }
fn b(x i16) { fmt.println(x) }
fn c(x i32) { fmt.println(x) }
fn d(x i64) { fmt.println(x) }

fn e(x u8)  { fmt.println(x) }
fn f(x u16) { fmt.println(x) }
fn g(x u32) { fmt.println(x) }
fn h(x u64) { fmt.println(x) }

fn main() {
    a(69)
    b(420)
    c(1337)
    d(80085)

    e(69)
    f(420)
    g(1337)
    h(80085)
}
