a :: (x: i8)  { println(x) }
b :: (x: i16) { println(x) }
c :: (x: i32) { println(x) }
d :: (x: i64) { println(x) }

e :: (x: u8)  { println(x) }
f :: (x: u16) { println(x) }
g :: (x: u32) { println(x) }
h :: (x: u64) { println(x) }

main :: () {
    a(69)
    b(420)
    c(1337)
    d(80085)

    e(69)
    f(420)
    g(1337)
    h(80085)
}
