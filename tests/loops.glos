package main

import "fmt"

fn main() {
    var i = 0
    for i < 5 {
        fmt::println(i)
        i = i + 1
    }

    for i = 0; i < 10; i = i + 2 {
        fmt::println(i)
    }

    for var j = 5; j > 0; j = j - 1 {
        fmt::println(j)
    }

    i = 0
    for {
        if i == 10 {
            return
        }

        fmt::println(i)
        i = i + 2
    }
}
