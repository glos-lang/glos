i := 0
for i < 5 {
    print i
    i = i + 1
}

for i = 0; i < 10; i = i + 2 {
    print i
}

for j := 5; j > 0; j = j - 1 {
    print j
}

for i = 0; i < 6; i = i + 1 {
    if i == 4 {
        continue
    }

    print i
}

for i = 0; i < 10; i = i + 1 {
    if i == 5 {
        break
    }

    print i
}
