mod main

fn main() {
    var i = 0
    for i < 5 {
        print i
        i = i + 1
    }

    for i = 0; i < 10; i = i + 2 {
        print i
    }

    for var j = 5; j > 0; j = j - 1 {
        print j
    }

    i = 0
    for {
        if i == 10 {
            return
        }

        print i
        i = i + 2
    }
}
