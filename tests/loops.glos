main :: () {
    i := 0
    for i < 5 {
        println(i)
        i = i + 1
    }

    for i = 0; i < 10; i = i + 2 {
        println(i)
    }

    for j := 5; j > 0; j = j - 1 {
        println(j)
    }

    for i = 0; i < 6; i = i + 1 {
        if i == 4 {
            continue
        }

        println(i)
    }

    for i = 0; i < 10; i = i + 1 {
        if i == 5 {
            break
        }

        println(i)
    }
}
