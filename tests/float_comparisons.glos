package main

import "fmt"

fn main() {
    fmt.println(2.0 > 1.0)
    fmt.println(1.0 > 1.0)
    fmt.println(0.0 > 1.0)

    fmt.println(2.0 >= 1.0)
    fmt.println(1.0 >= 1.0)
    fmt.println(0.0 >= 1.0)

    fmt.println(1.0 < 2.0)
    fmt.println(1.0 < 1.0)
    fmt.println(1.0 < 0.0)

    fmt.println(1.0 <= 2.0)
    fmt.println(1.0 <= 1.0)
    fmt.println(1.0 <= 0.0)

    fmt.println(1.0 == 1.0)
    fmt.println(1.0 == 2.0)

    fmt.println(1.0 != 2.0)
    fmt.println(1.0 != 1.0)
}
