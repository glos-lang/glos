main :: () {
    a := i8(69)
    b := i16(420)
    c := i32(1337)
    d := i64(80085)

    // Basics
    print a
    print b
    print c
    print d

    // Sizes
    print sizeof(a)
    print sizeof(b)
    print sizeof(c)
    print sizeof(d)

    // Comparisons
    print u64(1) > 0
    print u64(1) > -1
}
