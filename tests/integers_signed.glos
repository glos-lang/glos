main :: () {
    a := i8(69)
    b := i16(420)
    c := i32(1337)
    d := i64(80085)

    // Basics
    println(a)
    println(b)
    println(c)
    println(d)

    // Sizes
    println(sizeof(a))
    println(sizeof(b))
    println(sizeof(c))
    println(sizeof(d))

    // Comparisons
    println(u64(1) > 0)
    println(u64(1) > u64(-1))
}
