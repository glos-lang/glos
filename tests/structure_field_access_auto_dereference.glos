package main

import "fmt"

struct Iota {
    x i64
}

fn single(i &Iota) {
    i.x = i.x + 1
}

fn double(i &&Iota) {
    i.x = i.x + 1
}

fn main() {
    var iota = Iota {x: 67}
    var ptr = &iota
    fmt::println(iota.x)

    single(ptr)
    fmt::println(iota.x)

    double(&ptr)
    fmt::println(iota.x)
}
