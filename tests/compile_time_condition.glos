package main

import "fmt"

when true {
	fn main() {
		fmt::println(foo())
	}
}

when false {
	fn main() {
		fmt::println("This does not get checked or compiled")
	}
} else {
	fn foo() i64 {
		return bar()
	}
}

when false {
	fn bar() []u8 {
		return "Urmom"
	}
} else when true {
	fn bar() i64 {
		return 69
	}
}
