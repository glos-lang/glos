package main

import "fmt"

fn print_i64s(xs []i64) {
    for var i = 0; i < xs.count; i += 1 {
        fmt::println(xs[i])
    }
}

fn main() {
    var xs = []i64 {69, 420, 1337}
    print_i64s(xs[..])

    var ys = [3]i64 {
        0: 69,
        1: 420,
        2: 1337
    }
    print_i64s(ys[..])
}
