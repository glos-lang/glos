package main

import "fmt"

fn typeof(s fmt::Show) {
	if s.type == rawptr {
		fmt::println("typeof(", s, ") => raw pointer")
		return
	}

	match s.type {
		i64: fmt::println("typeof(", s, ") => i64")
		bool: fmt::println("typeof(", s, ") => bool")
		[]char: fmt::println("typeof(", s, ") => string")
		else: fmt::println("typeof(", s, ") => unknown")
	}
}

fn main() {
	typeof(nil)
	typeof(69)
	typeof(true)
	typeof("Urmom")
	typeof('E')
}
