Vec2 :: struct {
    x: i64,
    y: i64
}

make_vec2 :: (x: i64, y: i64) -> Vec2 {
    vec: Vec2
    vec.x = x
    vec.y = y
    return vec
}

Mat4 :: struct {
    v1: Vec2,
    v2: Vec2
}

make_mat4 :: (v1: Vec2, v2: Vec2) -> Mat4 {
    mat: Mat4
    mat.v1 = v1
    mat.v2 = v2
    return mat
}

main :: () {
    x := make_mat4(make_vec2(69, 420), make_vec2(1337, 80085)).v1.x
    y := make_mat4(make_vec2(69, 420), make_vec2(1337, 80085)).v1.y
    print x
    print y
}
