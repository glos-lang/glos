package main

import "fmt"

struct Vec2 {
    x i32
    y i32
}

fn foo(v &Vec2) {
    v.x = 42
    v.y = 69
}

fn bar(v Vec2) {
    fmt.println(v.x)
    fmt.println(v.y)
}

fn vec2(x i32, y i32) Vec2 {
    var v Vec2
    v.x = x
    v.y = y
    return v
}

fn main() {
    var pos Vec2
    fmt.println(sizeof(pos))

    foo(&pos)
    bar(pos)
    bar(vec2(420, 1337))
    fmt.println(vec2(80085, 69).x)
}
