Vec2 :: struct {
    x: i32,
    y: i32
}

foo :: (v: &Vec2) {
    v.x = 42
    v.y = 69
}

bar :: (v: Vec2) {
    print v.x
    print v.y
}

vec2 :: (x: i32, y: i32) -> Vec2 {
    v: Vec2
    v.x = x
    v.y = y
    return v
}

main :: () {
    pos: Vec2
    print sizeof(pos)

    foo(&pos)
    bar(pos)
    bar(vec2(420, 1337))
}
