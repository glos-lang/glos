Vec2 :: struct {
    x: i32
    y: i32
}

foo :: (v: &Vec2) {
    v.x = 42
    v.y = 69
}

bar :: (v: Vec2) {
    println(v.x)
    println(v.y)
}

vec2 :: (x: i32, y: i32) -> Vec2 {
    v: Vec2
    v.x = x
    v.y = y
    return v
}

main :: () {
    pos: Vec2
    println(sizeof(pos))

    foo(&pos)
    bar(pos)
    bar(vec2(420, 1337))
    println(vec2(80085, 69).x)
}
