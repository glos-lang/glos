package main

import "fmt"

fn main() {
    var a = <u8> 69
    var b = <u16> 420
    var c = <u32> 1337
    var d = <u64> 80085

    fmt::println(a)
    fmt::println(sizeof(a))

    fmt::println(b)
    fmt::println(sizeof(b))

    fmt::println(c)
    fmt::println(sizeof(c))

    fmt::println(d)
    fmt::println(sizeof(d))
}
