package main

fn alloc_i64s(n i64) []i64 {
    extern {
        fn malloc(size u64) rawptr
    }

    var ptr = <*i64> malloc(<u64> (n * sizeof<i64>))
    return ptr[..n]
}

fn print_i64s(xs []i64) {
    for var i = 0; i < len(xs); i += 1 {
        print xs[i]
    }
}

fn main() {
    var xs = alloc_i64s(6)[..]
    for var i = 0; i < len(xs); i += 1 {
        xs[i] = <i64> i * 2
    }
    print_i64s(xs[1..])
}
