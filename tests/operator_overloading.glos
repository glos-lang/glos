main :: () {
    a := Int32 {10}
    b := Int32 {3}

    println(a + b)
    println(a - b)
    println(a * b)
    println(a / b)
    println(a % b)

    c := a
    c += b
    println(c)

    c = a
    c -= b
    println(c)

    c = a
    c *= b
    println(c)

    c = a
    c /= b
    println(c)

    c = a
    c %= b
    println(c)

    println(a)
    println(a != b)

    println(b < a)
    println(b <= a)

    println(a > b)
    println(a >= b)

    println(a <= a)
    println(a >= a)
}

Int32 :: struct {
    x: i32
}

operator + :: (this: Int32, that: Int32) -> Int32 {
    this.x += that.x
    return this
}

operator - :: (this: Int32, that: Int32) -> Int32 {
    this.x -= that.x
    return this
}

operator * :: (this: Int32, that: Int32) -> Int32 {
    this.x *= that.x
    return this
}

operator / :: (this: Int32, that: Int32) -> Int32 {
    this.x /= that.x
    return this
}

operator % :: (this: Int32, that: Int32) -> Int32 {
    this.x %= that.x
    return this
}

operator > :: (this: Int32, that: Int32) -> bool {
    return this.x > that.x
}

operator >= :: (this: Int32, that: Int32) -> bool {
    return this.x >= that.x
}

operator < :: (this: Int32, that: Int32) -> bool {
    return this.x < that.x
}

operator <= :: (this: Int32, that: Int32) -> bool {
    return this.x <= that.x
}

operator == :: (this: Int32, that: Int32) -> bool {
    return this.x == that.x
}

operator != :: (this: Int32, that: Int32) -> bool {
    return this.x != that.x
}
