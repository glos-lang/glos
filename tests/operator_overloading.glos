main :: () {
    a := Int32 {10}
    b := Int32 {3}

    println(a + b)
    println(a - b)
    println(a * b)
    println(a / b)
    println(a % b)
    println(-a)

    c := a
    c += b
    println(c)

    c = a
    c -= b
    println(c)

    c = a
    c *= b
    println(c)

    c = a
    c /= b
    println(c)

    c = a
    c %= b
    println(c)

    println(a)
    println(a != b)

    println(b < a)
    println(b <= a)

    println(a > b)
    println(a >= b)

    println(a <= a)
    println(a >= a)
}

Int32 :: struct {
    x: i32
}

add :: (this: Int32, that: Int32) -> Int32 {
    this.x += that.x
    return this
}

sub :: (this: Int32, that: Int32) -> Int32 {
    this.x -= that.x
    return this
}

mul :: (this: Int32, that: Int32) -> Int32 {
    this.x *= that.x
    return this
}

div :: (this: Int32, that: Int32) -> Int32 {
    this.x /= that.x
    return this
}

mod :: (this: Int32, that: Int32) -> Int32 {
    this.x %= that.x
    return this
}

neg :: (this: Int32) -> Int32 {
    this.x = -this.x
    return this
}

compare :: (this: Int32, that: Int32) -> Comparison {
    if this.x < that.x {
        return .LT
    }

    if this.x > that.x {
        return .GT
    }

    return .EQ
}
