main :: () {
    {
        foo :: (x := 69) { println(x) }
        foo()
        foo(420)
    }

    {
        foo :: (enabled := true, debug := false) {
            println(enabled)
            println(debug)
        }

        foo()
        foo(false)
        foo(false, true)
    }

    {
        foo :: (name: string, greeting := "Hello,") {
            print(greeting)
            print(" ")
            println(name)
        }

        foo("world")
        foo("urmom", "I slept with")
    }

    {
        Opts :: struct {
            a: i32
            b: i32
        }

        foo :: (opts := Opts {69, 420}) {
            println(opts.a)
            println(opts.b)
        }

        foo()
        foo(Opts {1337, 80085})
    }
}
