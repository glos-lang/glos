main :: () {
    {
        foo :: (x := 69) { print x }
        foo()
        foo(420)
    }

    {
        foo :: (enabled := true, debug := false) {
            print enabled
            print debug
        }

        foo()
        foo(false)
        foo(false, true)
    }

    {
        foo :: (name: string, greeting := "Hello,") {
            display(greeting)
            display(" ")
            display(name)
            display("\n")
        }

        foo("world")
        foo("urmom", "I slept with")
    }

    {
        Opts :: struct {
            a: i32
            b: i32
        }

        foo :: (opts := Opts {69, 420}) {
            print opts.a
            print opts.b
        }

        foo()
        foo(Opts {1337, 80085})
    }
}

display :: (s: string) {
    for i := 0; i < s.count; i += 1 {
        extern { putchar :: (c: i32) -> i32 }
        putchar(i32(s[i]))
    }
}
