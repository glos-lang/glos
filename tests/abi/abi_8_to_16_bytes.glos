S16 :: struct {
    x: i64
    y: i64
}

extern {
    s16_foo :: (s: S16)
    s16_bar :: (s0: S16, s1: S16, s2: S16, s3: S16)
    s16_baz :: (s0: S16, s1: S16, s2: S16, s3: S16, s4: S16)
    s16_ret :: (x: i64, y: i64) -> S16
}

main :: () {
    s16_foo(S16 {1, 2})
    s16_bar(S16 {1, 2}, S16 {3, 4}, S16 {5, 6}, S16 {7, 8})
    s16_baz(S16 {1, 2}, S16 {3, 4}, S16 {5, 6}, S16 {7, 8}, S16 {9, 10})
    s16_foo(s16_ret(1, 2))
    s16_foo(() -> S16 { return S16 {1, 2} }())
}
