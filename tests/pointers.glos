package main

import "fmt"

fn f() {
    var x = 69
    var p = &x

    fmt.println(x)
    *p = 420
    fmt.println(x)
}

fn g() {
    var a = 69
    var b = 420

    var y = &a
    var z = &y

    fmt.println(a)
    fmt.println(b)

    *y = 420

    fmt.println(a)
    fmt.println(b)

    *z = &b
    *y = 69

    fmt.println(a)
    fmt.println(b)

    **z = 1337

    fmt.println(a)
    fmt.println(b)
}

fn main() {
    f()
    g()
}
