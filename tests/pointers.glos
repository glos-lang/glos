f :: () {
    x := 69
    p := &x

    println(x)
    *p = 420
    println(x)
}

g :: () {
    a := 69
    b := 420

    y := &a
    z := &y

    println(a)
    println(b)

    *y = 420

    println(a)
    println(b)

    *z = &b
    *y = 69

    println(a)
    println(b)

    **z = 1337

    println(a)
    println(b)
}

main :: () {
    f()
    g()

    x: i64
    y := &x
    z := y + &i64(80085)
    println(z - y)
}
