Show :: union {
    i64
    string
}

show :: (s: Show) {
    print s.case

    if s == {
    case i64;    print s
    case string; fmt.println(s)
    case;        fmt.println("nil")
    }

    fmt :: #import "fmt"
}

main :: () {
    s: Show
    show(s)
    show(Show(69))
    show(Show("Urmom"))

    s = Show(420)
    if s == i64 {
        assert(s == 420)
    }
}
