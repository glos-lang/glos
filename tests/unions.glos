Show :: union {
    i64
    string
}

show :: (s: Show) {
    println(s.case)

    if s == {
    case i64;    println(s)
    case string; println(s)
    case;        println("nil")
    }
}

main :: () {
    s: Show
    show(s)
    show(Show(69))
    show(Show("Urmom"))

    s = Show(420)
    if s == i64 {
        assert(s == 420)
    }
}
