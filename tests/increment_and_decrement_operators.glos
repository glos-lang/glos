basics :: () {
    x := 69
    println(x++)

    assert(x == 70)
    println(--x)

    x = 68
    println(++x)

    println(x--)
    assert(x == 68)
}

dereference :: () {
    x := 68
    p := &x

    (*p)++
    println(x)
}

pointer :: () {
    s: [6]char
    p := s.data

    *p++ = 'U'
    *p++ = 'r'
    *p++ = 'm'
    *p++ = 'o'
    *p++ = 'm'
    *p++ = '\0'

    puts(s.data)

    extern {
        puts :: (s: &char) -> i32
    }
}

main :: () {
    basics()
    dereference()
    pointer()
}
