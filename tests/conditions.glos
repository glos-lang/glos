package main

import "fmt"

fn main() {
    if true {
        fmt.println(69)
    }

    if false {
        fmt.println(69)
    }

    if true {
        fmt.println(420)
    } else {
        fmt.println(1337)
    }

    if false {
        fmt.println(420)
    } else {
        fmt.println(1337)
    }

    if false {
        fmt.println(420)
    } else if true {
        fmt.println(80085)
    } else {
        fmt.println(8008135)
    }
}
