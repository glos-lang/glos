main :: () {
    if true {
        println(69)
    }

    if false {
        println(69)
    }

    if true {
        println(420)
    } else {
        println(1337)
    }

    if false {
        println(420)
    } else {
        println(1337)
    }

    if false {
        println(420)
    } else if true {
        println(80085)
    } else {
        println(8008135)
    }
}
