main :: () {
    // Untyped enumeration
    {
        Foo :: enum {
            A
            B
            C = 69
            D
        }

        println(Foo.A)
        println(i64(Foo.A))
        println(Foo.B)
        println(i64(Foo.B))
        println(Foo.C)
        println(i64(Foo.C))
        println(Foo.D)
        println(i64(Foo.D))
    }

    // Typed enumeration
    {
        Foo :: enum u8 {
            A
            B
            C = 42
        }
        #assert(sizeof(Foo) == sizeof(u8))

        println(Foo.A)
        println(u8(Foo.A))
        println(Foo.B)
        println(u8(Foo.B))
        println(Foo.C)
        println(u8(Foo.C))
    }
}
