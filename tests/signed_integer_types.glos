package main

import "fmt"

fn main() {
    var a = <i8> 69
    var b = <i16> 420
    var c = <i32> 1337
    var d = <i64> 80085

    fmt::println(a)
    fmt::println(sizeof(a))

    fmt::println(b)
    fmt::println(sizeof(b))

    fmt::println(c)
    fmt::println(sizeof(c))

    fmt::println(d)
    fmt::println(sizeof(d))
}
