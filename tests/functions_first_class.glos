apply :: (x: i64, f: (_: i64)) {
    f(x)
}

map :: (x: i64, f: (_: i64) -> i64) -> i64 {
    return f(x)
}

main :: () {
    foo := () { println(69) }
    foo()

    foo = () { println(420) }
    foo()

    apply(2674, (x: i64) { println(x / 2) })
    println(map(26695, (x: i64) -> i64 { return x * 3 }))
}
